# BondScribe configuration. Copy to ".env" only if you need to override the
# defaults — out of the box BondScribe auto-detects your hardware.

# Audio source: "mic" (microphone) or "loopback" (desktop audio via WASAPI).
AUDIO_MODE=mic

# Optional: pin a specific input device index.
# List devices with:  python -m backend.audio --list
# AUDIO_DEVICE_INDEX=

# --- Speech model (all optional) ---
# Pick a preset. Default is "fastest" (lowest latency). You can also switch
# presets live from the model picker in the app.
#   fastest   tiny interim / small final        (lowest latency)
#   balanced  small interim / distil-large-v3   (near-large accuracy, GPU)
#   accurate  small interim / large-v3          (best, slightly slower)
# WHISPER_PRESET=fastest
#
# Device/compute are auto-detected (GPU -> cuda, else cpu). Override only if
# you know what you want:
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=int8_float16   # float16 (GPU) or int8 (CPU)
#
# Advanced: override the preset's individual models.
# Model options (multilingual): small, medium, large-v3, distil-large-v3
# WHISPER_MODEL=small
# WHISPER_INTERIM_MODEL=tiny
