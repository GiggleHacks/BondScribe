{
  "name": "bondscribe-desktop",
  "version": "0.2.4",
  "private": true,
  "description": "BondScribe — live transcript + AI panes with auto-copy and prepend prompt.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.bondscribe.desktop",
    "productName": "BondScribe",
    "win": {
      "icon": "../assets/bondscribe.ico",
      "target": "dir"
    },
    "asar": false,
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "preload.js",
      "chat-preload.js",
      "webview-preload.js",
      "renderer.html",
      "icon.png",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
